---
import BaseLayout from './BaseLayout.astro';
import SourceBadge from '../components/astro/SourceBadge.astro';
import { formatDate } from '../lib/seo';
import { useTranslations, path } from '../i18n/ui';
import type { CollectionEntry } from 'astro:content';
import { getWriteupProject } from '../lib/relations';
import { getPostAlternates } from '../lib/content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, summary, publishedAt, tags, kind, lang } = post.data;
const t = useTranslations(lang);

// Se o post é writeup de um projeto, busca o cartão "Sobre o projeto X".
const project = await getWriteupProject(post);
const alternates = await getPostAlternates(post);
---

<BaseLayout title={title} description={summary} type="article" publishedAt={publishedAt} alternates={alternates}>
  <article class="prose-page">
    <header class="mb-8 border-b border-border pb-6">
      <div class="mb-3 flex flex-wrap items-center gap-2 text-sm text-muted">
        <SourceBadge source="native" kind={kind} />
        <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt, lang)}</time>
        {tags.length > 0 && <span aria-hidden="true">·</span>}
        {tags.map((tag) => <span class="text-muted">#{tag}</span>)}
      </div>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
      <p class="mt-3 text-lg text-muted">{summary}</p>
    </header>

    {
      project && (
        <aside class="card mb-8 not-prose">
          <p class="text-xs uppercase tracking-wide text-muted">{t('project.about')}</p>
          <div class="mt-1 flex flex-wrap items-center justify-between gap-3">
            <div>
              <a href={path(lang, 'projects', project.data.translationKey)} class="text-lg font-semibold no-underline">
                {project.data.title}
              </a>
              <p class="text-sm text-muted">{project.data.summary}</p>
            </div>
            <a class="btn" href={path(lang, 'projects', project.data.translationKey)}>{t('project.view')}</a>
          </div>
        </aside>
      )
    }

    <div class="article-body">
      <slot />
    </div>

    <footer class="mt-12 border-t border-border pt-6 text-sm text-muted">
      <a href={path(lang, 'writing')} class="no-underline">{t('post.allWriting')}</a>
    </footer>
  </article>
</BaseLayout>
