---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/astro/ProjectCard.astro';
import { getCollection } from 'astro:content';

// Destaques primeiro; depois mantém ordem alfabética estável.
const projects = (await getCollection('projects', (e) => e.data.lang === 'pt')).sort((a, b) => {
  if (a.data.highlight !== b.data.highlight) return Number(b.data.highlight) - Number(a.data.highlight);
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout title="Projetos" description="Vitrine curada de projetos, enriquecida com metadados vivos do GitHub.">
  <header class="mb-8 max-w-2xl">
    <h1 class="text-3xl font-bold tracking-tight">Projetos</h1>
    <p class="mt-2 text-muted">
      Curadoria manual: só o que escolhi destacar. Estrelas, linguagem e último
      commit vêm do GitHub via pipeline desacoplado.
    </p>
  </header>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {projects.map((project) => <ProjectCard project={project} />)}
  </div>
</BaseLayout>
