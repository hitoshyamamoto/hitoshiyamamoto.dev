---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/astro/PostCard.astro';
import ProjectCard from '../components/astro/ProjectCard.astro';
import { getUnifiedFeed } from '../lib/content';
import { getCollection } from 'astro:content';

const feed = (await getUnifiedFeed()).slice(0, 4);
const projects = (await getCollection('projects'))
  .sort((a, b) => Number(b.data.highlight) - Number(a.data.highlight))
  .slice(0, 3);
---

<BaseLayout>
  <section class="mx-auto max-w-2xl py-8 text-center sm:py-14">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Hitoshi Yamamoto</h1>
    <p class="mt-4 text-lg text-muted">
      Engenharia, escrita e demos interativos. Um hub em código que reúne meus
      <a href="/escritos">escritos</a>, <a href="/projetos">projetos</a> e
      <a href="/labs">labs</a> num só lugar.
    </p>
    <div class="mt-6 flex justify-center gap-3">
      <a class="btn" href="/projetos">Ver projetos</a>
      <a class="btn" href="/sobre">Sobre mim</a>
    </div>
  </section>

  <section class="mt-8">
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="text-xl font-semibold tracking-tight">Escritos recentes</h2>
      <a href="/escritos" class="text-sm no-underline">ver todos →</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {feed.map((item) => <PostCard item={item} />)}
    </div>
  </section>

  <section class="mt-12">
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="text-xl font-semibold tracking-tight">Projetos em destaque</h2>
      <a href="/projetos" class="text-sm no-underline">ver todos →</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
