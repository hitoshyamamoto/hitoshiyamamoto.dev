---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada">
  <section class="mx-auto max-w-md py-20 text-center">
    <p class="font-mono text-6xl font-bold text-accent">404</p>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight">Página não encontrada</h1>
    <p class="mt-2 text-muted">O link pode estar quebrado ou a página foi movida.</p>
    <a href="/" class="btn mt-6">← Voltar para a home</a>
  </section>
</BaseLayout>
