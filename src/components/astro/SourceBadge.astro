---
import { getLocaleFromUrl, useTranslations } from '../../i18n/ui';

// Selo de origem: nativo (article/interactive) vs Medium.
interface Props {
  source: 'native' | 'medium';
  kind?: 'article' | 'interactive';
}
const { source, kind } = Astro.props;

const t = useTranslations(getLocaleFromUrl(Astro.url));
const label =
  source === 'medium' ? t('badge.medium') : kind === 'interactive' ? t('badge.interactive') : t('badge.native');
---

<span
  class:list={[
    'badge',
    source === 'medium'
      ? 'border-border text-muted'
      : kind === 'interactive'
        ? 'border-accent/40 text-accent'
        : 'border-accent/30 text-fg',
  ]}
>
  {source === 'native' && kind === 'interactive' && <span aria-hidden="true">▶</span>}
  {label}
</span>
