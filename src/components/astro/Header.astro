---
import ThemeToggle from '../react/ThemeToggle.tsx';

const links = [
  { href: '/escritos', label: 'Escritos' },
  { href: '/projetos', label: 'Projetos' },
  { href: '/labs', label: 'Labs' },
  { href: '/sobre', label: 'Sobre' },
];

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/80 backdrop-blur">
  <nav class="container-page flex h-14 items-center justify-between">
    <a href="/" class="font-mono text-sm font-semibold no-underline tracking-tight">
      hitoshiyamamoto<span class="text-accent">.dev</span>
    </a>
    <div class="flex items-center gap-1 sm:gap-2">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              'rounded-md px-2.5 py-1.5 text-sm no-underline transition-colors hover:text-accent',
              isActive(l.href) ? 'text-fg font-medium' : 'text-muted',
            ]}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <ThemeToggle client:load />
    </div>
  </nav>
</header>
