---
import ProjectLinks from './ProjectLinks.astro';
import { getGithubMeta } from '../../lib/content';
import { getProjectRelations, getProjectLanguages } from '../../lib/relations';
import { formatDate } from '../../lib/seo';
import { getLocaleFromUrl, useTranslations, path } from '../../i18n/ui';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const meta = project.data.repo ? (await getGithubMeta()).get(project.data.repo) : undefined;
const { lab, writeup } = await getProjectRelations(project, locale);
const languages = await getProjectLanguages(project, locale);
---

<article class="card flex flex-col gap-3 hover:border-accent/50">
  <div class="flex items-start justify-between gap-3">
    <a href={path(locale, 'projects', project.data.translationKey)} class="no-underline">
      <h3 class="text-lg font-semibold tracking-tight text-fg hover:text-accent">
        {project.data.title}
      </h3>
    </a>
    {project.data.highlight && <span class="badge border-accent/40 text-accent">{t('project.highlight')}</span>}
  </div>

  <p class="text-sm text-muted">{project.data.summary}</p>

  {
    meta && (
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted">
        {meta.language && (
          <span class="inline-flex items-center gap-1">
            <span class="h-2 w-2 rounded-full bg-accent" aria-hidden="true" />
            {meta.language}
          </span>
        )}
        <span>★ {meta.stars}</span>
        {meta.lastCommit && <span>{t('project.lastCommit')} {formatDate(new Date(meta.lastCommit), locale)}</span>}
        {meta.license && <span>{meta.license}</span>}
      </div>
    )
  }

  <div class="mt-1">
    <ProjectLinks repoUrl={meta?.url} demoSlug={lab?.id} writeupSlug={writeup?.id} />
  </div>

  {
    languages.length > 0 && (
      <div class="mt-3 flex items-center gap-1.5 border-t border-border pt-3">
        {languages.map((l) =>
          l.current ? (
            <span class="badge border-accent/40 text-accent" aria-current="true">
              {l.label}
            </span>
          ) : (
            <a href={l.href} hreflang={l.lang} class="badge border-border text-muted no-underline hover:border-accent hover:text-accent">
              {l.label}
            </a>
          ),
        )}
      </div>
    )
  }
</article>
