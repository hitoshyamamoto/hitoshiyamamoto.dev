---
import type { CollectionEntry } from 'astro:content';
import { getLocaleFromUrl, useTranslations, path, type Locale } from '../../i18n/ui';

interface Props {
  lab: CollectionEntry<'labs'>;
}
const { lab } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const KIND: Record<Locale, Record<CollectionEntry<'labs'>['data']['kind'], string>> = {
  pt: { static: 'client-side', wasm: 'WebAssembly', hosted: 'hospedado', realtime: 'tempo real' },
  en: { static: 'client-side', wasm: 'WebAssembly', hosted: 'hosted', realtime: 'real-time' },
};
const kindLabel = KIND[locale][lab.data.kind];
const live = lab.data.status === 'live';
---

<a
  href={path(locale, 'labs', lab.id)}
  class="card group flex flex-col gap-3 no-underline transition-colors hover:border-accent/50"
>
  <div class="relative aspect-video overflow-hidden rounded-lg border border-border bg-bg">
    <div
      class="h-full w-full bg-cover bg-center transition-transform duration-300 group-hover:scale-[1.04]"
      style={`background-image: url(${lab.data.poster});`}
    />
    <div class="absolute inset-0 flex items-center justify-center bg-black/0 opacity-0 transition duration-200 group-hover:bg-black/35 group-hover:opacity-100">
      <span class="flex items-center gap-1.5 rounded-full bg-white/90 px-3 py-1.5 text-sm font-medium text-black">
        <span aria-hidden="true">▶</span> {t('lab.open')}
      </span>
    </div>
  </div>

  <div class="flex items-start justify-between gap-2">
    <h3 class="text-lg font-semibold tracking-tight text-fg group-hover:text-accent">{lab.data.title}</h3>
    <span
      class:list={[
        'badge shrink-0',
        live ? 'border-emerald-500/40 text-emerald-500' : 'border-border text-muted',
      ]}
    >
      <span class:list={['h-1.5 w-1.5 rounded-full', live ? 'bg-emerald-500' : 'bg-muted']} aria-hidden="true" />
      {live ? 'live' : 'wip'}
    </span>
  </div>

  <p class="text-sm text-muted">{lab.data.summary}</p>

  <div class="mt-auto flex items-center gap-2 pt-1 text-xs text-muted">
    <span class="inline-flex items-center gap-1">
      <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true" />
      {kindLabel}
    </span>
  </div>
</a>
